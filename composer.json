  "description": "TYPO3 backend module for PPL DeepL V3 batch translation",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Pawel Pliousnin",
      "email": "pliousnin@ppl-ds.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.2",
    "typo3/cms-core": "^12.4",
    "typo3/cms-backend": "^12.4",
    "ppl/ppl-deepl-v3-requests": "@dev"
  },
  "autoload": {
