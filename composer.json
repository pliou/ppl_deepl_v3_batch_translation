{
  "name": "ppl/ppl-deepl-v3-batch-translation",
  "description": "TYPO3 12.4 backend workspace for controlled page tree and content element translation with DeepL V3.",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Pawel Pliousnin",
      "email": "pliousnin@ppl-ds.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-mbstring": "*",
    "ppl/ppl-deepl-v3-requests": "^12.4",
    "typo3/cms-backend": "^12.4",
    "typo3/cms-core": "^12.4",
    "typo3/cms-extbase": "^12.4",
    "typo3/cms-fluid": "^12.4"
  },
  "autoload": {
    "psr-4": {
      "Ppl\\PplDeeplV3BatchTranslation\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ppl\\PplDeeplV3BatchTranslation\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "12.4.x-dev"
    },
    "typo3/cms": {
      "extension-key": "ppl_deepl_v3_batch_translation"
    }
  }
}
