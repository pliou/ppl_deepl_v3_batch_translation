{
  "name": "ppl/ppl-deepl-v3-batch-translation",
  "description": "TYPO3 14 backend workspace for controlled page tree and content element translation with DeepL V3.",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Pawel Pliousnin",
      "email": "pliousnin@ppl-ds.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ppl/ppl-deepl-v3-requests": "^14.0",
    "typo3/cms-backend": "^14.0",
    "typo3/cms-core": "^14.0",
    "typo3/cms-extbase": "^14.0",
    "typo3/cms-fluid": "^14.0"
  },
  "autoload": {
    "psr-4": {
      "Ppl\\PplDeeplV3BatchTranslation\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ppl\\PplDeeplV3BatchTranslation\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "14.x-dev"
    },
    "typo3/cms": {
      "extension-key": "ppl_deepl_v3_batch_translation"
    }
  }
}
